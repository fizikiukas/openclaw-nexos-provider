{
  "name": "openclaw-nexos-provider",
  "version": "0.1.0",
  "description": "Nexos AI model provider plugin for OpenClaw — access Claude, GPT, Gemini, Grok and 60+ models through one API key.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "clawhub",
    "nexos",
    "nexos-ai",
    "llm",
    "ai",
    "model-provider"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --target node22 --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "openclaw": ">=2026.7.1-2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "2026.7.1-2",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "nexos",
      "nexos-anthropic"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1-2",
      "minGatewayVersion": "2026.7.1-2"
    },
    "build": {
      "openclawVersion": "2026.7.1-2",
      "pluginSdkVersion": "2026.7.1-2"
    }
  }
}
